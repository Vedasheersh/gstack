## Phase 2: Target Analysis (pre-design check)

Before designing, quickly characterize the target region:

```bash
python3 - << 'PYEOF'
import sys
try:
    from Bio.PDB import PDBParser, NeighborSearch
    import numpy as np

    parser = PDBParser(QUIET=True)
    structure = parser.get_structure("target", "<TARGET_PDB>")
    model = structure[0]
    chain = model["<TARGET_CHAIN>"]

    hotspots = [<HOTSPOT_RESNUMS>]  # integer list

    # Get hotspot residues
    hotspot_res = []
    for resnum in hotspots:
        try:
            res = chain[resnum]
            hotspot_res.append(res)
        except KeyError:
            print(f"WARNING: residue {resnum} not found in chain")

    # Compute center of hotspot patch
    coords = []
    for res in hotspot_res:
        if "CA" in res:
            coords.append(res["CA"].get_vector().get_array())
    if coords:
        center = np.mean(coords, axis=0)
        print(f"HOTSPOT_CENTER: {center}")
        spread = np.max(np.linalg.norm(np.array(coords) - center, axis=1))
        print(f"HOTSPOT_SPREAD: {spread:.1f} Angstrom")
        if spread > 20:
            print("WARNING: hotspot residues are spread > 20 Å — consider splitting into sub-patches")

    # Check B-factors at hotspot
    high_bfactor = [r for r in hotspot_res if any(a.get_bfactor() > 50 for a in r.get_atoms())]
    if high_bfactor:
        print(f"WARNING: {len(high_bfactor)} hotspot residues have B-factor > 50 (flexible/uncertain)")

    print("TARGET_ANALYSIS_DONE")
except ImportError:
    print("BioPython not available — skipping pre-analysis")
except Exception as e:
    print(f"Pre-analysis error (non-blocking): {e}")
PYEOF
```

Report findings to user. If warnings exist, surface them but don't block — let user decide.

