## Phase 3: Secondary Structure

```bash
# Run DSSP if available (requires mkdssp installed)
if command -v mkdssp &>/dev/null; then
    mkdssp -i <TARGET_PDB> -o /tmp/target.dssp 2>/dev/null && echo "DSSP_DONE" || echo "DSSP_FAILED"
    # Parse and summarize helix/sheet content
    python3 -c "
ss = open('/tmp/target.dssp').read()
lines = [l for l in ss.split('\n') if len(l) > 16 and l[13] != '!']
helix = sum(1 for l in lines if l[16] in 'GHI')
sheet = sum(1 for l in lines if l[16] in 'BE')
loop  = sum(1 for l in lines if l[16] in ' ST')
total = helix + sheet + loop
if total > 0:
    print(f'HELIX: {helix} ({100*helix//total}%)')
    print(f'SHEET: {sheet} ({100*sheet//total}%)')
    print(f'LOOP:  {loop} ({100*loop//total}%)')
" 2>/dev/null || echo "DSSP_PARSE_FAILED"
else
    echo "DSSP_UNAVAILABLE: install with 'conda install -c salilab dssp'"
fi
```

