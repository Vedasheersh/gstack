# /analyze-structure

You are characterizing a protein target to inform binder design. Apply full protein
design expertise from CLAUDE.md. Output concrete, actionable recommendations —
not generic descriptions.

---

## Phase 1: Get the Structure

Via AskUserQuestion if not provided:
- PDB file path, OR
- RCSB ID (4-character, e.g. "1YCR")
- Target chain ID (default: A; show available chains if unknown)
- Optional: region of interest (e.g. "the C-terminal domain" or residues 40-90)

If RCSB ID provided:
```bash
PDB_ID="<ID>"
wget -q "https://files.rcsb.org/download/${PDB_ID}.pdb" -O "${PDB_ID}.pdb" && \
  echo "Downloaded ${PDB_ID}.pdb" || echo "FETCH_FAILED"
```

If fetch fails, try mmCIF:
```bash
wget -q "https://files.rcsb.org/download/${PDB_ID}.cif" -O "${PDB_ID}.cif" && \
  echo "Downloaded ${PDB_ID}.cif (mmCIF)" || echo "FETCH_FAILED_BOTH"
```

---

## Phase 2: Structure Analysis

Run the full analysis. Handle import errors gracefully — report what's available.

```python
import sys, json
try:
    from Bio.PDB import PDBParser, DSSP, NeighborSearch, is_aa
    from Bio.PDB.SASA import ShrakeRupley
    import numpy as np
    BIOPYTHON = True
except ImportError:
    BIOPYTHON = False
    print("WARNING: BioPython not available — install with: pip install biopython")

if BIOPYTHON:
    TARGET_PDB = "<TARGET_PDB>"
    CHAIN_ID = "<CHAIN_ID>"

    parser = PDBParser(QUIET=True)
    structure = parser.get_structure("target", TARGET_PDB)
    model = structure[0]

    # --- Basic info ---
    chains = list(model.get_chains())
    chain_ids = [c.id for c in chains]
    chain = model[CHAIN_ID]
    residues = [r for r in chain.get_residues() if is_aa(r)]
    print(f"CHAINS: {chain_ids}")
    print(f"TARGET_CHAIN: {CHAIN_ID}")
    print(f"N_RESIDUES: {len(residues)}")
    print(f"RESIDUE_RANGE: {residues[0].get_id()[1]}–{residues[-1].get_id()[1]}")

    # --- B-factors ---
    bfactors = []
    flexible_regions = []
    for res in residues:
        if "CA" in res:
            bf = res["CA"].get_bfactor()
            bfactors.append((res.get_id()[1], bf))
    avg_bf = np.mean([b for _, b in bfactors])
    high_bf = [(r, b) for r, b in bfactors if b > 50]
    print(f"AVG_BFACTOR: {avg_bf:.1f}")
    if high_bf:
        print(f"HIGH_BFACTOR_RESIDUES: {[r for r, _ in high_bf[:10]]} ...")

    # --- Atom clashes (simple VdW check) ---
    all_atoms = list(model.get_atoms())
    ns = NeighborSearch(all_atoms)
    clashes = []
    seen = set()
    for atom in chain.get_atoms():
        close = ns.search(atom.get_vector().get_array(), 2.0, "A")
        for other in close:
            if other.get_parent() != atom.get_parent():
                key = tuple(sorted([atom.get_full_id(), other.get_full_id()]))
                if key not in seen:
                    seen.add(key)
                    clashes.append((atom.get_full_id(), other.get_full_id()))
    print(f"VDW_CLASHES: {len(clashes)}")

    # --- Surface residues (SASA) ---
    try:
        sr = ShrakeRupley()
        sr.compute(structure, level="R")
        surface_res = []
        buried_res = []
        for res in residues:
            if hasattr(res, 'sasa'):
                if res.sasa > 40:
                    surface_res.append(res.get_id()[1])
                else:
                    buried_res.append(res.get_id()[1])
        print(f"SURFACE_RESIDUES_N: {len(surface_res)}")
        print(f"BURIED_RESIDUES_N: {len(buried_res)}")
    except Exception as e:
        print(f"SASA_SKIP: {e}")

    # --- Hotspot candidates: surface residues with low B-factor (stable + accessible) ---
    stable_surface = []
    for resnum, bf in bfactors:
        if bf < 30 and resnum in surface_res:
            try:
                res = chain[resnum]
                resname = res.get_resname()
                stable_surface.append((resnum, resname, bf))
            except:
                pass
    print(f"HOTSPOT_CANDIDATES (stable+surface): {stable_surface[:20]}")

    print("ANALYSIS_DONE")
```

