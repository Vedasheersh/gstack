# /setup-protein-env

Discover and configure your protein design tool environment. This writes
`.proteinstack/config.yaml` in your current directory. Run once per project
(or re-run to update paths after installing new tools).

---

## Phase 1: GPU Check

```bash
python3 -c "
import subprocess, sys
# CUDA via torch
try:
    import torch
    if torch.cuda.is_available():
        n = torch.cuda.device_count()
        names = [torch.cuda.get_device_name(i) for i in range(n)]
        print(f'CUDA_AVAILABLE: {n} device(s): {names}')
        print(f'GPU_DEVICE: cuda:0')
    else:
        print('CUDA_NOT_AVAILABLE')
except ImportError:
    print('TORCH_NOT_INSTALLED')
# Apple MPS
try:
    import torch
    if torch.backends.mps.is_available():
        print('MPS_AVAILABLE (Apple Silicon)')
        print('GPU_DEVICE: mps')
except:
    pass
" 2>/dev/null || echo "GPU_CHECK_FAILED"
```

---

## Phase 2: Tool Discovery

Check common installation locations for each tool. Ask for path if not found.

```bash
echo "=== Checking RFdiffusion3 ==="
for p in \
    "$HOME/RFdiffusion" \
    "$HOME/software/RFdiffusion" \
    "/opt/protein/RFdiffusion" \
    "$(conda info --base 2>/dev/null)/envs/SE3nv/lib/python*/site-packages/rfdiffusion" \
    ; do
    [ -f "$p/run_inference.py" ] && echo "RFDIFFUSION_FOUND: $p" && break
done

echo "=== Checking BindCraft ==="
for p in \
    "$HOME/BindCraft" \
    "$HOME/software/BindCraft" \
    "/opt/protein/BindCraft" \
    ; do
    [ -f "$p/run_bindcraft.py" ] && echo "BINDCRAFT_FOUND: $p" && break
done

echo "=== Checking ProteinMPNN ==="
for p in \
    "$HOME/ProteinMPNN" \
    "$HOME/software/ProteinMPNN" \
    "/opt/protein/ProteinMPNN" \
    ; do
    [ -f "$p/protein_mpnn_run.py" ] && echo "MPNN_FOUND: $p" && break
done

echo "=== Checking AlphaFold2 ==="
for p in \
    "$HOME/alphafold" \
    "$HOME/software/alphafold" \
    "/opt/protein/alphafold" \
    ; do
    [ -f "$p/run_alphafold.py" ] && echo "AF2_FOUND: $p" && break
done

echo "=== Checking ESMFold ==="
python3 -c "import esm; print('ESMFOLD_FOUND: (pip package)')" 2>/dev/null || \
for p in "$HOME/esm" "$HOME/software/esm" "/opt/protein/esm"; do
    [ -f "$p/esm/scripts/fold.py" ] && echo "ESMFOLD_FOUND: $p" && break
done

echo "=== Checking Boltz ==="
python3 -c "import boltz; print('BOLTZ_FOUND: (pip package)')" 2>/dev/null || echo "BOLTZ_NOT_FOUND"

echo "=== Checking PXDesign ==="
for p in "$HOME/PXDesign" "$HOME/software/PXDesign" "/opt/protein/PXDesign"; do
    [ -d "$p" ] && echo "PXDESIGN_FOUND: $p" && break
done
```

For any tool that is NOT found, ask the user via AskUserQuestion:
- "Where is <TOOL> installed? (Enter path, or skip if not installed)"

---

## Phase 3: Validate Paths

For each found/provided path, verify the key entrypoint exists and is executable:

```bash
# Example checks — adapt per tool
[ -f "<RFDIFFUSION_PATH>/run_inference.py" ] && echo "RFD_OK" || echo "RFD_BAD_PATH"
[ -f "<MPNN_PATH>/protein_mpnn_run.py" ]     && echo "MPNN_OK" || echo "MPNN_BAD_PATH"
[ -f "<AF2_PATH>/run_alphafold.py" ]          && echo "AF2_OK"  || echo "AF2_BAD_PATH"
```

---

## Phase 4: Write Config

```bash
mkdir -p .proteinstack
```

Write `.proteinstack/config.yaml` with discovered paths and GPU info:

```yaml
# proteinstack configuration
# Generated by /setup-protein-env on <timestamp>
# Re-run /setup-protein-env to update

backends:
  rfdiffusion3:
    enabled: <true|false>
    path: <path or null>
    weights: <path or null>   # e.g. ~/RFdiffusion/models/
  bindcraft:
    enabled: <true|false>
    path: <path or null>
  pxdesign:
    enabled: <true|false>
    path: <path or null>

sequence_design:
  mpnn:
    enabled: <true|false>
    path: <path or null>
    version: "1.0.1"
  fampnn:
    enabled: false
    path: null

validation:
  alphafold2:
    enabled: <true|false>
    path: <path or null>
    db_path: null   # path to genetic databases (needed for MSA mode)
  esmfold:
    enabled: <true|false>
    path: <path or null>   # null if installed as pip package
  boltz:
    enabled: <true|false>
    path: null   # null if installed as pip package

gpu:
  available: <true|false>
  device: "<cuda:0|mps|cpu>"
  n_devices: <n>
```

