## Phase 4: Membrane Protein Handling (if IS_MEMBRANE_PROTEIN)

*Skip entirely if not a membrane protein.*

Query OPM for the membrane-oriented structure:

```bash
TARGET_PDB_ID="<TARGET_PDB_ID_LOWER>"

# Download OPM-oriented structure
curl -s "https://opm-assets.storage.googleapis.com/pdb/${TARGET_PDB_ID}.pdb" \
  -o "/tmp/opm_${TARGET_PDB_ID}.pdb" && echo "OPM_DL_OK" || echo "OPM_NOT_IN_DATABASE"
```

If OPM download fails, try querying their search page and inform the user.

Parse OPM structure to extract membrane boundaries and identify extracellular residues:

```python
import re
import numpy as np

opm_pdb = "/tmp/opm_<TARGET_PDB_ID>.pdb"

# Parse membrane thickness from REMARK records
membrane_thickness = None
with open(opm_pdb) as f:
    for line in f:
        m = re.search(r"Hydrophobic thickness:\s*([\d.]+)", line)
        if m:
            membrane_thickness = float(m.group(1))
            break

if membrane_thickness is None:
    # Fall back: DUM atoms mark membrane boundaries
    # DUM atoms in OPM are at Z = ±(thickness/2)
    dum_z = []
    with open(opm_pdb) as f:
        for line in f:
            if line.startswith("HETATM") and "DUM" in line:
                try:
                    z = float(line[46:54].strip())
                    dum_z.append(z)
                except:
                    pass
    if dum_z:
        membrane_thickness = (max(dum_z) - min(dum_z))
        print(f"MEMBRANE_THICKNESS (from DUM atoms): {membrane_thickness:.1f} Å")
        mem_upper = max(dum_z)
        mem_lower = min(dum_z)
    else:
        print("WARNING: Could not determine membrane boundaries from OPM file")
        mem_upper = 15.0
        mem_lower = -15.0
else:
    mem_upper = membrane_thickness / 2
    mem_lower = -membrane_thickness / 2
    print(f"MEMBRANE_THICKNESS (from REMARK): {membrane_thickness:.1f} Å")
    print(f"MEMBRANE_BOUNDARIES: Z = [{mem_lower:.1f}, {mem_upper:.1f}]")

# Identify extracellular residues
# For a standard type-I single-pass: extracellular = Z > mem_upper
# For multi-pass: extracellular loops = Z > mem_upper
# We'll collect all residues with CA Z > mem_upper + 3 Å buffer
extracellular_residues = []
intracellular_residues = []
membrane_residues = []

from Bio.PDB import PDBParser, is_aa
parser = PDBParser(QUIET=True)
structure = parser.get_structure("opm", opm_pdb)
model = structure[0]
target_chain = model["<TARGET_CHAIN>"]

for res in target_chain.get_residues():
    if not is_aa(res):
        continue
    resnum = res.get_id()[1]
    if "CA" not in res:
        continue
    z = res["CA"].get_vector().get_array()[2]

    if z > mem_upper + 3:
        extracellular_residues.append(resnum)
    elif z < mem_lower - 3:
        intracellular_residues.append(resnum)
    else:
        membrane_residues.append(resnum)

print(f"EXTRACELLULAR_RESIDUES ({len(extracellular_residues)}): {extracellular_residues}")
print(f"TM_CORE_RESIDUES ({len(membrane_residues)}): {membrane_residues}")
print(f"INTRACELLULAR_RESIDUES ({len(intracellular_residues)}): {intracellular_residues}")
```

**Report:** Show diagram of topology (extracellular / TM / intracellular residue counts).
All downstream epitope analysis is restricted to `extracellular_residues` only.

