## Phase 6: Cluster Refinement and Output

After either path, refine clusters spatially and select the final epitope sets.

```python
import numpy as np
from Bio.PDB import PDBParser, is_aa

# Load structure (use complex or target-only depending on path)
parser = PDBParser(QUIET=True)
structure = parser.get_structure("target", "/tmp/<BEST_PDB>.pdb")
chain = structure[0]["<TARGET_CHAIN>"]

# Build CA coordinate map
ca_coords = {}
resnames = {}
for res in chain.get_residues():
    if is_aa(res) and "CA" in res:
        ca_coords[res.get_id()[1]] = res["CA"].get_vector().get_array()
        resnames[res.get_id()[1]] = res.get_resname()

# For each rough cluster from Phase 5, find all residues within 10 Å
# of any cluster member (spatial expansion)
raw_clusters = <CLUSTERS_FROM_PHASE_5>
final_epitopes = []

for i, cluster_core in enumerate(raw_clusters):
    cluster_residues = set(cluster_core)
    # Expand: add any residue within 10 Å of core
    for resnum, coord in ca_coords.items():
        for core_res in cluster_core:
            if core_res in ca_coords:
                dist = np.linalg.norm(coord - ca_coords[core_res])
                if dist < 10.0:
                    cluster_residues.add(resnum)

    # Filter to surface-accessible ones (if SASA data available)
    cluster_list = sorted(cluster_residues)
    final_epitopes.append({
        "epitope_id": f"E{i+1}",
        "core_residues": cluster_core,
        "expanded_residues": cluster_list,
        "n_residues": len(cluster_list),
        "hotspot_suggestion": cluster_core[:5],  # top contributors as hotspots
    })

print(f"FINAL_EPITOPES: {len(final_epitopes)}")
for ep in final_epitopes:
    print(f"  {ep['epitope_id']}: {ep['n_residues']} residues, "
          f"core={ep['core_residues']}, hotspots={ep['hotspot_suggestion']}")
```

